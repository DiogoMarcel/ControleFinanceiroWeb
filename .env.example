# =============================================================================
# CONTROLE FINANCEIRO WEB — Variáveis de Ambiente
# Copie este arquivo para .env e preencha com seus valores
# NUNCA commite o arquivo .env
# =============================================================================

# -----------------------------------------------------------------------------
# BACKEND (apps/api)
# -----------------------------------------------------------------------------

# PostgreSQL — mesmo banco do projeto Delphi
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/contasfamilia?schema=public"

# Firebase Admin SDK (gerar em: Firebase Console > Project Settings > Service Accounts)
FIREBASE_PROJECT_ID="seu-firebase-project-id"
FIREBASE_CLIENT_EMAIL="firebase-adminsdk-xxxxx@seu-projeto.iam.gserviceaccount.com"
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nSUA_CHAVE_AQUI\n-----END PRIVATE KEY-----\n"

# Servidor
PORT=3001
NODE_ENV=development

# -----------------------------------------------------------------------------
# FRONTEND (apps/web)
# -----------------------------------------------------------------------------

# URL da API backend
VITE_API_URL=http://localhost:3001/api/v1

# Firebase Web SDK (obter em: Firebase Console > Project Settings > Your apps)
VITE_FIREBASE_API_KEY="sua-api-key"
VITE_FIREBASE_AUTH_DOMAIN="seu-projeto.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID="seu-firebase-project-id"
VITE_FIREBASE_APP_ID="1:000000000000:web:xxxxxxxxxxxxxxxx"
